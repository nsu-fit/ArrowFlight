{
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true},
      "targets": [{"expr": "sum(arrowflight_parquet_queries_active)", "legendFormat": "active", "refId": "A"}],
      "title": "Active Parquet queries",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "qps"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true},
      "targets": [{"expr": "sum(rate(arrowflight_parquet_queries_total[$__rate_interval]))", "legendFormat": "queries/s", "refId": "A"}],
      "title": "Completed queries / second",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Planned Parquet bytes processed by Flight scans; this is logical throughput, not physical disk traffic.",
      "fieldConfig": {"defaults": {"unit": "Bps"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true},
      "targets": [{"expr": "sum(rate(arrowflight_parquet_logical_input_bytes_total[$__rate_interval]))", "legendFormat": "logical bytes/s", "refId": "A"}],
      "title": "Parquet logical throughput",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto", "wideLayout": true},
      "targets": [{"expr": "sum(increase(arrowflight_parquet_query_failures_total[$__range]))", "legendFormat": "failures", "refId": "A"}],
      "title": "Query failures in range",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 1, "showPoints": "never"}, "max": 100, "min": 0, "unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "100 - (avg by (cpu) (rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])) * 100)", "legendFormat": "CPU {{cpu}}", "refId": "A"}],
      "title": "Linux CPU usage per core",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 15, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "used", "refId": "A"},
        {"expr": "node_memory_MemAvailable_bytes", "legendFormat": "available", "refId": "B"},
        {"expr": "node_memory_Cached_bytes", "legendFormat": "page cache", "refId": "C"}
      ],
      "title": "Linux RAM",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 6, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "percent"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!~\"prometheus|grafana|node-exporter|cadvisor|\"}[$__rate_interval])) * 100", "legendFormat": "{{container_label_com_docker_compose_service}}", "refId": "A"}],
      "title": "Container CPU (100% = one core)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 12, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [{"expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service!~\"prometheus|grafana|node-exporter|cadvisor|\"})", "legendFormat": "{{container_label_com_docker_compose_service}}", "refId": "A"}],
      "title": "Container working-set RAM",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "id": 9,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "arrowflight_jvm_threads_live", "legendFormat": "{{instance}} live", "refId": "A"},
        {"expr": "arrowflight_jvm_threads_daemon", "legendFormat": "{{instance}} daemon", "refId": "B"},
        {"expr": "node_processes_threads", "legendFormat": "host threads", "refId": "C"},
        {"expr": "node_processes_pids", "legendFormat": "host processes", "refId": "D"}
      ],
      "title": "Threads and processes",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "id": 10,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "arrowflight_jvm_heap_used_bytes", "legendFormat": "{{instance}} used", "refId": "A"},
        {"expr": "arrowflight_jvm_heap_max_bytes", "legendFormat": "{{instance}} max", "refId": "B"},
        {"expr": "arrowflight_jvm_nonheap_used_bytes", "legendFormat": "{{instance}} non-heap", "refId": "C"}
      ],
      "title": "Flight JVM memory",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "End-to-end server duration: resolve/read Parquet, filter/aggregate and stream result. It is not kernel I/O wait alone.",
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "id": 11,
      "options": {"legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, path) (rate(arrowflight_parquet_query_duration_seconds_bucket[5m])))", "legendFormat": "p95 {{path}}", "refId": "A"},
        {"expr": "sum by (path) (rate(arrowflight_parquet_query_duration_seconds_sum[5m])) / clamp_min(sum by (path) (rate(arrowflight_parquet_query_duration_seconds_count[5m])), 1e-9)", "legendFormat": "mean {{path}}", "refId": "B"},
        {"expr": "sum(rate(arrowflight_parquet_materialization_duration_seconds_total[5m])) / clamp_min(sum(rate(arrowflight_parquet_materializations_total[5m])), 1e-9)", "legendFormat": "mean HDFS cache copy", "refId": "C"}
      ],
      "title": "Parquet query/read duration",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Logical input comes from planned Parquet file sizes. Cache materialization is actual Hadoop bytes copied for Acero.",
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "Bps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "id": 12,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum by (path) (rate(arrowflight_parquet_logical_input_bytes_total[$__rate_interval]))", "legendFormat": "logical {{path}}", "refId": "A"},
        {"expr": "sum(rate(arrowflight_parquet_materialization_bytes_total[$__rate_interval]))", "legendFormat": "HDFS -> Acero cache", "refId": "B"},
        {"expr": "sum by (device) (rate(node_disk_read_bytes_total{device!~\"loop.*|ram.*\"}[$__rate_interval]))", "legendFormat": "disk {{device}}", "refId": "C"}
      ],
      "title": "Parquet and physical read throughput",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "Bps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 36},
      "id": 13,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum by (device) (rate(node_disk_read_bytes_total{device!~\"loop.*|ram.*\"}[$__rate_interval]))", "legendFormat": "read {{device}}", "refId": "A"},
        {"expr": "-sum by (device) (rate(node_disk_written_bytes_total{device!~\"loop.*|ram.*\"}[$__rate_interval]))", "legendFormat": "write {{device}}", "refId": "B"}
      ],
      "title": "Linux disk I/O",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"custom": {"drawStyle": "line", "fillOpacity": 8, "lineWidth": 1, "showPoints": "never"}, "min": 0, "unit": "Bps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 36},
      "id": 14,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right", "showLegend": true}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "targets": [
        {"expr": "sum by (container_label_com_docker_compose_service) (rate(container_network_receive_bytes_total[$__rate_interval]))", "legendFormat": "RX {{container_label_com_docker_compose_service}}", "refId": "A"},
        {"expr": "-sum by (container_label_com_docker_compose_service) (rate(container_network_transmit_bytes_total[$__rate_interval]))", "legendFormat": "TX {{container_label_com_docker_compose_service}}", "refId": "B"}
      ],
      "title": "Container network I/O",
      "type": "timeseries"
    }
  ],
