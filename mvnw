# Maven Wrapper start script
# The contents of this file will be written to disk during Maven Wrapper setup.
# You can safely replace it with the content generated by "mvn wrapper:wrapper".

PRG="$0"
while [ -h "$PRG" ]; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`/"$link"
  fi
done
SAVED="`pwd`"
cd "`dirname \"$PRG\"`/" >/dev/null
APP_HOME="`pwd -P`"
cd "$SAVED" >/dev/null

DEFAULT_JVM_OPTS="-Xmx64m -Xms64m"

if [ -z "$JAVA_HOME" ]; then
  javaExecutable="`which javac`"
  if [ -n "$javaExecutable" ] && ! [ "`expr \"$javaExecutable\" : '\([^ ]*\)'`" = "no" ]; then
    # Use the JDK's bin directory to find java
    if [ -x "$javaExecutable/../bin/java" ]; then
      JAVA_HOME="`dirname \"$javaExecutable\"`/.."
      javaExecutable="$JAVA_HOME/bin/java"
    else
      javaExecutable="`which java`"
    fi
  else
    javaExecutable="`which java`"
  fi
else
  javaExecutable="$JAVA_HOME/bin/java"
fi

if [ ! -x "$javaExecutable" ]; then
  echo "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
  echo "Please set the JAVA_HOME variable in your environment to match the"
  echo "location of your Java installation."
  exit 1
fi

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-`pwd`}"
export MAVEN_PROJECTBASEDIR

WRAPPER_LAUNCHER=org.apache.maven.wrapper.MavenWrapperMain

exec "$javaExecutable" \
  $DEFAULT_JVM_OPTS \
  $JAVA_OPTS \
  -classpath "$APP_HOME/.mvn/wrapper/maven-wrapper.jar" \
  $WRAPPER_LAUNCHER \
  "$@"
